@using System.Globalization
@using Sistema.APP.DTOs
@model FinancasCarteirasDto
@{
    var br = CultureInfo.GetCultureInfo("pt-BR");
    string Money(decimal value) => value.ToString("C", br);
    string Percent(decimal value) => value.ToString("N2", br) + "%";
}

<div data-aos="fade-up" data-aos-duration="220">
    <div class="card">
        <div class="card-body">
            <div class="finance-island-header d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
                <h5 class="mb-0">Carteiras</h5>
                <a class="btn btn-sm btn-outline-primary" asp-action="Transacoes">
                    <i class="bi bi-list-ul me-1"></i>Ver transações
                </a>
            </div>
            <div class="table-responsive">
                <table class="table table-sm align-middle finance-assets">
                    <thead>
                        <tr>
                            <th>Carteira</th>
                            <th class="text-end">% patrimônio</th>
                            <th class="text-end">Dia</th>
                            <th class="text-end">Valor</th>
                            <th class="text-end">Resultado</th>
                            <th class="text-end">Ativos</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var carteira in Model.Carteiras)
                    {
                        var resultadoClass = carteira.ResultadoNaoRealizado >= 0 ? "text-success" : "text-danger";
                        var diaClass = carteira.VariacaoDiaPercentual >= 0 ? "text-success" : "text-danger";
                        var collapseId = $"carteira-{carteira.Id}";
                        <tr>
                            <td>
                                <button class="btn btn-link p-0 text-decoration-none fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false">
                                    <i class="bi bi-chevron-down me-1"></i>@carteira.Nome
                                </button>
                                <div class="small text-secondary">@carteira.Tipo</div>
                            </td>
                            <td class="text-end">@Percent(carteira.PercentualPatrimonio)</td>
                            <td class="text-end @diaClass">@Percent(carteira.VariacaoDiaPercentual)</td>
                            <td class="text-end">@Money(carteira.ValorMercado)</td>
                            <td class="text-end @resultadoClass">
                                @Money(carteira.ResultadoNaoRealizado)
                                <div class="small">@Percent(carteira.ResultadoNaoRealizadoPercentual)</div>
                            </td>
                            <td class="text-end">@carteira.Ativos.ToString("N0", br)</td>
                        </tr>
                        <tr class="collapse" id="@collapseId">
                            <td colspan="6" class="bg-body-tertiary">
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle mb-0">
                                        <thead>
                                            <tr>
                                                <th>Ativo</th>
                                                <th class="text-end">% carteira</th>
                                                <th class="text-end">Qtde</th>
                                                <th class="text-end">Dia</th>
                                                <th class="text-end">Valor</th>
                                                <th class="text-end">Resultado</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                        @foreach (var ativo in carteira.Itens)
                                        {
                                            var ativoResultadoClass = ativo.ResultadoNaoRealizado >= 0 ? "text-success" : "text-danger";
                                            var ativoDiaClass = (ativo.VariacaoDiaPercentual ?? 0) >= 0 ? "text-success" : "text-danger";
                                            <tr>
                                                <td>
                                                    <div class="fw-semibold">@ativo.Ativo</div>
                                                    <div class="small text-secondary">@ativo.Classe &middot; @ativo.Symbol &middot; @ativo.Status</div>
                                                </td>
                                                <td class="text-end">@Percent(ativo.PercentualCarteira)</td>
                                                <td class="text-end">@ativo.Quantidade.ToString("N4", br)</td>
                                                <td class="text-end @ativoDiaClass">@(ativo.VariacaoDiaPercentual.HasValue ? Percent(ativo.VariacaoDiaPercentual.Value) : "-")</td>
                                                <td class="text-end">@Money(ativo.ValorMercado)</td>
                                                <td class="text-end @ativoResultadoClass">
                                                    @Money(ativo.ResultadoNaoRealizado)
                                                    <div class="small">@Percent(ativo.ResultadoNaoRealizadoPercentual)</div>
                                                </td>
                                            </tr>
                                        }
                                        </tbody>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (Model.Carteiras.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-secondary py-4">
                                Nenhuma carteira com posição aberta. Adicione transações ou importe seus relatórios.
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
