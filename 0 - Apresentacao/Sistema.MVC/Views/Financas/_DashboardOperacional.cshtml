@using System.Globalization
@using Sistema.APP.DTOs
@model FinancasOperacionalDto
@{
    var br = CultureInfo.GetCultureInfo("pt-BR");
}

<div class="row g-3" data-aos="fade-up" data-aos-duration="220">
    <div class="col-xl-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="mb-0">Posições estimadas</h6>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Posicoes" asp-route-abertas="true">Ver todas</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead><tr><th>Ativo</th><th>Classe</th><th class="text-end">Qtde</th><th>Confiança</th></tr></thead>
                        <tbody>
                        @foreach (var item in Model.PosicoesAbertas)
                        {
                            <tr>
                                <td>@item.Ativo</td>
                                <td>@item.Classe</td>
                                <td class="text-end">@item.Quantidade.ToString("N4", br)</td>
                                <td><span class="badge text-bg-warning">@item.Confianca</span></td>
                            </tr>
                        }
                        @if (Model.PosicoesAbertas.Count == 0)
                        {
                            <tr><td colspan="4" class="text-center text-secondary py-3">Sem posições estimadas.</td></tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="mb-0">Alertas de confiabilidade</h6>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Alertas">Ver todos</a>
                </div>
                <div class="list-group list-group-flush">
                @foreach (var alerta in Model.Alertas)
                {
                    <div class="list-group-item px-0">
                        <div class="d-flex justify-content-between gap-2">
                            <strong>@alerta.Codigo</strong>
                            <span class="badge text-bg-secondary">@alerta.Severidade</span>
                        </div>
                        <div class="small text-secondary">@alerta.Mensagem</div>
                    </div>
                }
                @if (Model.Alertas.Count == 0)
                {
                    <div class="text-secondary small py-3">Sem alertas.</div>
                }
                </div>
            </div>
        </div>
    </div>
</div>
