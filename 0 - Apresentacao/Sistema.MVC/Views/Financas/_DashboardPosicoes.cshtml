@using System.Globalization
@using Sistema.APP.DTOs
@model FinancasPosicoesDashboardDto
@{
    var br = CultureInfo.GetCultureInfo("pt-BR");
    string Money(decimal value) => value.ToString("C2", br);
    var c = Model.Composicao;
    // Fonte do preço → cor do chip (consistente com a coluna da tabela).
    string FonteClasse(string fonte) => fonte switch
    {
        "Custo" => "text-bg-secondary",
        "Fechamento B3" => "text-bg-primary",
        _ => "text-bg-success"
    };
}

<div class="card h-100" data-aos="fade-up" data-aos-duration="220">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="mb-0"><i class="bi bi-clipboard-check me-1"></i>Posições calculadas vs custódia</h6>
            <a class="btn btn-sm btn-outline-secondary" asp-action="Posicoes" asp-route-abertas="true">Ver todas</a>
        </div>

        @* F-L (a): de onde vem o valor de mercado — cotação ao vivo × fechamento B3 × custo/fallback. *@
        <div class="small text-secondary mb-1">Composição do valor</div>
        <div class="d-flex flex-wrap gap-2 mb-3">
            <span class="badge text-bg-success" title="Valorado por cotação ao vivo (Brapi/Binance)">
                Cotação ao vivo: @Money(c.ComCotacao)
            </span>
            <span class="badge text-bg-primary" title="Valorado pelo Preço de Fechamento da custódia B3">
                Fechamento B3: @Money(c.ComFechamentoB3)
            </span>
            <span class="badge text-bg-secondary" title="Fallback ao custo (preço médio) quando não há cotação utilizável">
                Custo (fallback): @Money(c.ComCusto)
            </span>
        </div>

        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Ativo</th>
                        <th class="text-end">Preço médio</th>
                        <th class="text-end">Valor</th>
                        <th>Fonte do preço</th>
                        <th class="text-end">Dif. vs B3</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in Model.Posicoes)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@p.Ticker</div>
                            <div class="small text-secondary">@p.Classe &middot; @p.Quantidade.ToString("N4", br)</div>
                        </td>
                        <td class="text-end">@Money(p.PrecoMedio)</td>
                        <td class="text-end">
                            @* F-Q: o valor abre a explicação (composição/fonte) — sem recalcular na UI. *@
                            <button type="button" class="btn btn-link btn-sm p-0 text-reset text-decoration-none fw-medium"
                                    data-explicar="posicao" data-ativo-id="@p.AtivoId" data-titulo="@p.Ticker"
                                    title="Explicar este valor">
                                @Money(p.ValorMercado) <i class="bi bi-info-circle small text-secondary"></i>
                            </button>
                        </td>
                        <td><span class="badge @FonteClasse(p.FontePreco)">@p.FontePreco</span></td>
                        <td class="text-end">
                            @if (p.DiferencaB3.HasValue)
                            {
                                <span class="@(p.DiferencaB3.Value >= 0 ? "text-success" : "text-danger")">
                                    @(p.DiferencaB3.Value >= 0 ? "+" : "")@Money(p.DiferencaB3.Value)
                                </span>
                            }
                            else
                            {
                                <span class="text-secondary" title="Sem snapshot da B3 para este ativo">—</span>
                            }
                        </td>
                    </tr>
                }
                @if (Model.Posicoes.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-secondary py-3">Sem posições calculadas.</td></tr>
                }
                </tbody>
            </table>
        </div>
        <div class="small text-secondary mt-2">
            <i class="bi bi-info-circle me-1"></i>"Dif. vs B3" compara o valor calculado com o fechamento da custódia oficial B3 (quando há snapshot).
        </div>
    </div>
</div>
