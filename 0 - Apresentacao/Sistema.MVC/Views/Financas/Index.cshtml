@{
    ViewData["Title"] = "Finanças";
}

@await Html.PartialAsync("_PageHeader", new PageHeaderViewModel
{
    Title = "Finanças",
    Description = "Acompanhe a evolução do patrimônio, o desempenho por carteira e seus ativos."
})

@await Html.PartialAsync("_FlashMessages")

<div class="finance-shell"
     id="financeDashboard"
     data-prepare-url="@Url.Action("PrepararDashboard", "Financas")"
     data-patrimonio-url="@Url.Action("DashboardPatrimonio", "Financas")"
     data-carteiras-url="@Url.Action("DashboardCarteiras", "Financas")"
     data-metas-url="@Url.Action("DashboardMetas", "Financas")"
     data-importacao-url="@Url.Action("DashboardImportacao", "Financas")"
     data-posicoes-url="@Url.Action("DashboardPosicoes", "Financas")"
     data-alertas-url="@Url.Action("DashboardAlertas", "Financas")"
     data-proventos-url="@Url.Action("DashboardProventos", "Financas")"
     data-calendario-proventos-url="@Url.Action("DashboardCalendarioProventos", "Financas")"
     data-reconciliacao-url="@Url.Action("DashboardReconciliacao", "Financas")"
     data-saude-cotacoes-url="@Url.Action("DashboardSaudeCotacoes", "Financas")"
     data-explicar-posicao-url="@Url.Action("ExplicarPosicao", "Financas")"
     data-explicar-patrimonio-url="@Url.Action("ExplicarPatrimonio", "Financas")"
     data-transacoes-url="@Url.Action("Transacoes", "Financas")">

    <section id="financePatrimonioIsland" class="finance-island mb-3" aria-busy="true" aria-live="polite">
        <div class="finance-skeleton finance-skeleton--hero" role="status">
            <span class="visually-hidden">Carregando patrimônio e evolução...</span>
        </div>
    </section>

    <section id="financeCarteirasIsland" class="finance-island mb-3" aria-busy="true" aria-live="polite">
        <div class="finance-skeleton finance-skeleton--table" role="status">
            <span class="visually-hidden">Carregando carteiras...</span>
        </div>
    </section>

    @* F-G: metas + rebalanceamento. A ilha fica vazia (parcial sem markup) quando nenhuma carteira tem peso-alvo. *@
    <section id="financeMetasIsland" class="finance-island mb-3" aria-busy="true" aria-live="polite">
        <div class="finance-skeleton finance-skeleton--table" role="status">
            <span class="visually-hidden">Carregando metas...</span>
        </div>
    </section>

    <section id="financeProventosIsland" class="finance-island mb-3" aria-busy="true" aria-live="polite">
        <div class="finance-skeleton finance-skeleton--table" role="status">
            <span class="visually-hidden">Carregando proventos...</span>
        </div>
    </section>

    @* F-T: calendário de proventos (realizado por mês×tipo + previsto/anunciado). A ilha fica vazia quando não há provento. *@
    <section id="financeCalendarioProventosIsland" class="finance-island mb-3" aria-busy="true" aria-live="polite">
        <div class="finance-skeleton finance-skeleton--table" role="status">
            <span class="visually-hidden">Carregando calendário de proventos...</span>
        </div>
    </section>

    @* F-M: card de reconciliação B3. A ilha fica vazia (parcial sem markup) quando não há ajustes. *@
    <section id="financeReconciliacaoIsland" class="finance-island mb-3" aria-busy="true" aria-live="polite">
        <div class="finance-skeleton finance-skeleton--table" role="status">
            <span class="visually-hidden">Carregando reconciliação...</span>
        </div>
    </section>

    @* F-S: saúde das cotações. A ilha fica vazia (parcial sem markup) quando não há ativo detido. *@
    <section id="financeSaudeCotacoesIsland" class="finance-island mb-3" aria-busy="true" aria-live="polite">
        <div class="finance-skeleton finance-skeleton--table" role="status">
            <span class="visually-hidden">Carregando saúde das cotações...</span>
        </div>
    </section>

    <section id="financeImportacaoIsland" class="finance-island mb-3" aria-busy="true" aria-live="polite">
        <div class="finance-skeleton" role="status">
            <span class="visually-hidden">Carregando dados de importação...</span>
        </div>
    </section>

    <div class="row g-3">
        <section id="financePosicoesIsland" class="finance-island col-xl-6" aria-busy="true" aria-live="polite">
            <div class="finance-skeleton finance-skeleton--table" role="status">
                <span class="visually-hidden">Carregando posições...</span>
            </div>
        </section>

        <section id="financeAlertasIsland" class="finance-island col-xl-6" aria-busy="true" aria-live="polite">
            <div class="finance-skeleton finance-skeleton--table" role="status">
                <span class="visually-hidden">Carregando alertas...</span>
            </div>
        </section>
    </div>
</div>

@await Html.PartialAsync("_NovaTransacaoModal")

@section Scripts {
    <script src="~/lib/apexcharts/apexcharts.min.js" asp-append-version="true"></script>
    <script src="~/js/financas.js" asp-append-version="true"></script>
}
