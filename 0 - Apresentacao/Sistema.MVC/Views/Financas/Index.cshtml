@using System.Globalization
@using Sistema.APP.DTOs
@model FinancasDashboardDto
@{
    ViewData["Title"] = "Finanças";
    var br = CultureInfo.GetCultureInfo("pt-BR");
    string Money(decimal value) => value.ToString("C", br);
    string Percent(decimal value) => value.ToString("N2", br) + "%";
}

@await Html.PartialAsync("_PageHeader", new PageHeaderViewModel
{
    Title = "Finanças",
    Description = "Acompanhe a evolução do patrimônio, o desempenho por setor e seus ativos — estilo Google Finance."
})

@await Html.PartialAsync("_FlashMessages")

<div class="finance-shell">
    @if (string.IsNullOrWhiteSpace(Model.Fonte) && !Model.AtivosCotados.Any())
    {
        <div class="alert alert-info d-flex align-items-center gap-2">
            <i class="bi bi-info-circle"></i>
            <div>Comece <strong>adicionando uma transação</strong> ou importando seus relatórios da B3/Binance. O gráfico e os setores aparecem assim que houver dados e cotações.</div>
        </div>
    }

    <div class="card finance-hero mb-3">
        <div class="card-body">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-2">
                <div>
                    <div class="text-secondary small" id="financeHeaderTitulo">Patrimônio total</div>
                    <div class="finance-hero-value" id="financeHeaderValor">@Money(Model.ValorMercadoTotal)</div>
                    <div class="finance-hero-delta @(Model.ResultadoNaoRealizadoTotal >= 0 ? "text-success" : "text-danger")" id="financeHeaderDelta">
                        @Money(Model.ResultadoNaoRealizadoTotal)
                    </div>
                </div>
                <div class="d-flex flex-column align-items-end gap-2">
                    <button class="btn btn-primary" type="button" data-abrir-modal="novaTransacaoModal">
                        <i class="bi bi-plus-circle me-1"></i>Adicionar transação
                    </button>
                    <a class="btn btn-outline-secondary btn-sm" asp-action="Resumo" asp-route-preset="mes">
                        <i class="bi bi-clipboard-data me-1"></i>Resumo do período
                    </a>
                </div>
            </div>

            <div class="finance-period-bar" id="financePeriodos"></div>
            <div id="financeEvolucao" class="finance-chart" data-evolucao-url="@Url.Action("Evolucao", "Financas")"></div>
            <div class="small text-secondary mt-2">
                <i class="bi bi-info-circle me-1"></i>Leitura estimada a partir das suas transações e cotações públicas. Não é recomendação de investimento.
            </div>
        </div>
    </div>

    <h5 class="mb-2">Setores</h5>
    <div class="finance-sectors mb-4" id="financeSetores">
        <div class="text-secondary small">Carregando setores...</div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
                <h5 class="mb-0">Ativos monitorados</h5>
                <a class="btn btn-sm btn-outline-primary" asp-action="Transacoes"><i class="bi bi-list-ul me-1"></i>Ver transações</a>
            </div>
            <div class="table-responsive">
                <table class="table table-sm align-middle finance-assets">
                    <thead>
                        <tr>
                            <th>Ativo</th>
                            <th class="text-end">Qtde</th>
                            <th class="text-end">Preço médio</th>
                            <th class="text-end">Preço atual</th>
                            <th class="text-end">Dia</th>
                            <th class="text-end">Mercado</th>
                            <th class="text-end">Retorno total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ativo in Model.AtivosCotados.OrderByDescending(x => x.ValorMercado))
                        {
                            var retClass = ativo.ResultadoNaoRealizado >= 0 ? "text-success" : "text-danger";
                            var diaClass = (ativo.VariacaoDiaPercentual ?? 0) >= 0 ? "text-success" : "text-danger";
                            <tr>
                                <td>
                                    <div class="fw-semibold">@ativo.Ativo</div>
                                    <div class="small text-secondary">@ativo.Classe · @ativo.Symbol</div>
                                </td>
                                <td class="text-end">@ativo.Quantidade.ToString("N4", br)</td>
                                <td class="text-end">@Money(ativo.PrecoMedio)</td>
                                <td class="text-end">@(ativo.PrecoAtual.HasValue ? Money(ativo.PrecoAtual.Value) : "-")</td>
                                <td class="text-end @diaClass">@(ativo.VariacaoDiaPercentual.HasValue ? Percent(ativo.VariacaoDiaPercentual.Value) : "-")</td>
                                <td class="text-end">@Money(ativo.ValorMercado)</td>
                                <td class="text-end @retClass">
                                    @Money(ativo.ResultadoNaoRealizado)
                                    <div class="small @retClass">@Percent(ativo.ResultadoNaoRealizadoPercentual)</div>
                                </td>
                            </tr>
                        }
                        @if (!Model.AtivosCotados.Any())
                        {
                            <tr><td colspan="7" class="text-center text-secondary py-3">Nenhum ativo com posição aberta. Adicione transações ou importe seus relatórios.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card finance-data-section">
        <div class="card-body">
            <button class="btn btn-link p-0 text-decoration-none d-flex align-items-center gap-2" type="button" data-bs-toggle="collapse" data-bs-target="#financeDados" aria-expanded="false">
                <i class="bi bi-database"></i><span class="fw-semibold">Dados &amp; importação</span>
                <i class="bi bi-chevron-down small"></i>
            </button>
            <div class="collapse mt-3" id="financeDados">
                <div class="finance-command-bar mb-3">
                    <div>
                        <div class="small text-secondary">Pasta monitorada</div>
                        <div class="fw-semibold">@(Model.ImportacaoArquivos?.PastaMonitorada ?? "Não configurada")</div>
                        <div class="small text-secondary">
                            @((Model.ImportacaoArquivos?.DocumentosProcessados ?? 0).ToString("N0", br)) documentos processados ·
                            Cotações: @(Model.CotacoesAtualizadasEm?.ToString("dd/MM/yyyy HH:mm", br) ?? "pendente")
                        </div>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <form asp-action="ImportarPasta" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-primary"><i class="bi bi-folder-symlink me-1"></i>Importar arquivos</button>
                        </form>
                        <form asp-action="AtualizarCotacoes" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-primary"><i class="bi bi-arrow-repeat me-1"></i>Atualizar cotações</button>
                        </form>
                    </div>
                </div>

                <div class="row g-3">
                    @foreach (var kpi in Model.Kpis)
                    {
                        <div class="col-md-6 col-xl-3">
                            <div class="card h-100"><div class="card-body">
                                <div class="text-secondary small">@kpi.Titulo</div>
                                <div class="fs-5 fw-semibold">@(kpi.Monetario ? Money(kpi.Valor) : kpi.Valor.ToString("N0", br))</div>
                                <div class="small text-secondary">@kpi.Subtitulo</div>
                            </div></div>
                        </div>
                    }
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-xl-6">
                        <div class="card h-100"><div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="mb-0">Posições estimadas (importação)</h6>
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Posicoes" asp-route-abertas="true">Ver todas</a>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <thead><tr><th>Ativo</th><th>Classe</th><th class="text-end">Qtde</th><th>Confiança</th></tr></thead>
                                    <tbody>
                                        @foreach (var item in Model.PosicoesAbertas)
                                        {
                                            <tr>
                                                <td>@item.Ativo</td>
                                                <td>@item.Classe</td>
                                                <td class="text-end">@item.Quantidade.ToString("N4", br)</td>
                                                <td><span class="badge text-bg-warning">@item.Confianca</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div></div>
                    </div>
                    <div class="col-xl-6">
                        <div class="card h-100"><div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="mb-0">Alertas de confiabilidade</h6>
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Alertas">Ver todos</a>
                            </div>
                            <div class="list-group list-group-flush">
                                @foreach (var alerta in Model.Alertas)
                                {
                                    <div class="list-group-item px-0">
                                        <div class="d-flex justify-content-between gap-2">
                                            <strong>@alerta.Codigo</strong>
                                            <span class="badge text-bg-secondary">@alerta.Severidade</span>
                                        </div>
                                        <div class="small text-secondary">@alerta.Mensagem</div>
                                    </div>
                                }
                                @if (!Model.Alertas.Any())
                                {
                                    <div class="text-secondary small">Sem alertas.</div>
                                }
                            </div>
                        </div></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_NovaTransacaoModal")

@section Scripts {
    <script src="~/lib/apexcharts/apexcharts.min.js" asp-append-version="true"></script>
    <script src="~/js/financas.js" asp-append-version="true"></script>
}
