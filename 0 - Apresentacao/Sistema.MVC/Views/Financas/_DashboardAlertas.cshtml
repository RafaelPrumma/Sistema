@using Sistema.APP.DTOs
@model IReadOnlyList<AlertaConfiabilidadeDto>

<div class="card h-100" data-aos="fade-up" data-aos-duration="220">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="mb-0">Alertas de confiabilidade</h6>
            <a class="btn btn-sm btn-outline-secondary" asp-action="Alertas">Ver todos</a>
        </div>
        <div class="list-group list-group-flush">
        @foreach (var alerta in Model)
        {
            <div class="list-group-item px-0">
                <div class="d-flex justify-content-between gap-2">
                    <strong>@alerta.Codigo</strong>
                    <span class="badge text-bg-secondary">@alerta.Severidade</span>
                </div>
                <div class="small text-secondary">@alerta.Mensagem</div>
            </div>
        }
        @if (Model.Count == 0)
        {
            <div class="text-secondary small py-3">Sem alertas.</div>
        }
        </div>
    </div>
</div>
