@{
    ViewData["Title"] = "Transações";
    var origem = ViewBag.Origem as string;
    var busca = ViewBag.Busca as string;
}

@await Html.PartialAsync("_PageHeader", new PageHeaderViewModel
{
    Title = "Transações",
    Description = "Fonte de verdade única: lançamentos importados e manuais. Tudo o que move a carteira sai daqui."
})

@await Html.PartialAsync("_FlashMessages")

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div class="d-flex align-items-end gap-2">
        <div>
            <label class="form-label small">Origem</label>
            <select class="form-select form-select-sm" id="fOrigem" style="max-width: 200px">
                <option value="">Todas as origens</option>
                <option value="Manual" selected="@(origem == "Manual")">Manual</option>
                <option value="Importacao" selected="@(origem == "Importacao")">Importação</option>
            </select>
        </div>
    </div>
    <button class="btn btn-primary" type="button" data-abrir-modal="novaTransacaoModal">
        <i class="bi bi-plus-circle me-1"></i>Adicionar transação
    </button>
</div>

<div class="card">
    <div class="card-body">
        <table id="tabelaTransacoes" class="table table-sm table-striped align-middle w-100">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Operação</th>
                    <th>Ativo</th>
                    <th>Classe</th>
                    <th class="text-end">Qtd</th>
                    <th class="text-end">Preço</th>
                    <th class="text-end">Total</th>
                    <th>Corretora</th>
                    <th>Fonte</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@await Html.PartialAsync("_NovaTransacaoModal")

<div id="editarTransacaoModal" data-titulo="Editar transação" data-icone="bi bi-pencil" data-largura="640" style="display:none">
    <form method="post" asp-action="EditarTransacao" id="formEditarTransacao" class="p-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="edId" />
        <input type="hidden" name="Ticker" id="edTicker" />
        <div class="row g-2">
            <div class="col-6">
                <label class="form-label">Operação</label>
                <select class="form-select" name="Tipo" id="edTipo">
                    <option value="Compra">Compra</option>
                    <option value="Venda">Venda</option>
                </select>
            </div>
            <div class="col-6">
                <label class="form-label">Data</label>
                <input class="form-control" type="date" name="Data" id="edData" required />
            </div>
            <div class="col-6">
                <label class="form-label">Quantidade</label>
                <input class="form-control" type="number" step="any" min="0" name="Quantidade" id="edQtd" required />
            </div>
            <div class="col-6">
                <label class="form-label">Preço unitário (R$)</label>
                <input class="form-control" type="number" step="any" min="0" name="PrecoUnitario" id="edPreco" required />
            </div>
            <div class="col-6">
                <label class="form-label">Taxas (R$)</label>
                <input class="form-control" type="number" step="any" min="0" name="Taxas" id="edTaxas" value="0" />
            </div>
            <div class="col-6">
                <label class="form-label">Corretora</label>
                <input class="form-control" name="Corretora" id="edCorretora" />
            </div>
            <div class="col-12">
                <label class="form-label">Observação</label>
                <input class="form-control" name="Observacao" id="edObs" />
            </div>
        </div>
        <div class="d-flex justify-content-end gap-2 mt-3">
            <button type="button" class="btn btn-outline-secondary" id="edCancelar">Cancelar</button>
            <button type="submit" class="btn btn-primary">Salvar alterações</button>
        </div>
    </form>
</div>

<form method="post" asp-action="ExcluirTransacao" id="formExcluirTransacao" class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="exId" />
</form>

@section Scripts {
    <script>
    (function () {
        if (!window.initDataTable) return;
        var $ = window.jQuery;
        var money = new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' });
        var qtdFmt = new Intl.NumberFormat('pt-BR', { maximumFractionDigits: 8 });
        function esc(v) { return (v == null ? '' : String(v)).replace(/[&<>"']/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]; }); }

        var tabela = window.initDataTable('#tabelaTransacoes', {
            url: '@Url.Action("TransacoesData", "Financas")',
            order: [[0, 'desc']],
            columns: [
                { data: 'data', render: function (d) { return d ? new Date(d).toLocaleDateString('pt-BR') : ''; } },
                { data: 'tipo', render: function (t) { return '<span class="badge ' + (t === 'Compra' ? 'text-bg-primary' : 'text-bg-success') + '">' + esc(t) + '</span>'; } },
                { data: 'ticker', render: esc },
                { data: 'classe', orderable: false, render: function (c) { return '<span class="small text-secondary">' + esc(c) + '</span>'; } },
                { data: 'quantidade', className: 'text-end', render: function (q) { return qtdFmt.format(q); } },
                { data: 'precoUnitario', className: 'text-end', render: function (p) { return money.format(p); } },
                { data: 'valorTotal', className: 'text-end', render: function (v) { return money.format(v); } },
                { data: 'corretora', render: function (c) { return '<span class="small">' + esc(c) + '</span>'; } },
                { data: 'fonte', orderable: false, render: function (f, t, row) { return '<span class="badge ' + (row.origem === 'Manual' ? 'text-bg-info' : 'text-bg-light border') + '">' + esc(f) + '</span>'; } },
                {
                    data: null, orderable: false, className: 'text-end text-nowrap', render: function (row) {
                        var dataIso = row.data ? String(row.data).substring(0, 10) : '';
                        return '<button class="btn btn-sm btn-outline-secondary js-editar" data-id="' + row.id + '" data-ticker="' + esc(row.ticker) + '" data-tipo="' + esc(row.tipo) + '" data-qtd="' + row.quantidade + '" data-preco="' + row.precoUnitario + '" data-data="' + dataIso + '" data-taxas="' + row.taxas + '" data-corretora="' + esc(row.corretora) + '" data-obs="' + esc(row.observacao || '') + '" title="Editar"><i class="bi bi-pencil"></i></button> ' +
                            '<button class="btn btn-sm btn-outline-danger js-excluir" data-id="' + row.id + '" title="Excluir"><i class="bi bi-trash"></i></button>';
                    }
                }
            ],
            extraData: function () { return { origem: document.getElementById('fOrigem').value }; }
        });

        // F-Q: deep-link "?busca=TICKER" vindo do "Explique este valor" pré-filtra a grid pelo ticker.
        var buscaInicial = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(busca ?? string.Empty));
        if (buscaInicial) { tabela.search(buscaInicial).draw(); }

        document.getElementById('fOrigem').addEventListener('change', function () { tabela.ajax.reload(); });

        // Editar (linhas dinâmicas → delegação)
        $(document).on('click', '.js-editar', function () {
            var b = this;
            document.getElementById('edId').value = b.dataset.id;
            document.getElementById('edTicker').value = b.dataset.ticker;
            document.getElementById('edTipo').value = b.dataset.tipo;
            document.getElementById('edData').value = b.dataset.data;
            document.getElementById('edQtd').value = b.dataset.qtd;
            document.getElementById('edPreco').value = b.dataset.preco;
            document.getElementById('edTaxas').value = b.dataset.taxas;
            document.getElementById('edCorretora').value = b.dataset.corretora;
            document.getElementById('edObs').value = b.dataset.obs || '';
            if (window.abrirModal) window.abrirModal('editarTransacaoModal');
            if ($ && typeof $('#editarTransacaoModal').iziModal === 'function') {
                $('#editarTransacaoModal').iziModal('setTitle', 'Editar ' + (b.dataset.ticker || 'transação'));
            }
        });

        // Excluir (form compartilhado)
        $(document).on('click', '.js-excluir', function () {
            if (!confirm('Excluir esta transação?')) return;
            document.getElementById('exId').value = this.dataset.id;
            document.getElementById('formExcluirTransacao').submit();
        });

        var cancelar = document.getElementById('edCancelar');
        if (cancelar) cancelar.addEventListener('click', function () { if (window.fecharModal) window.fecharModal('editarTransacaoModal'); });
    })();
    </script>
}
