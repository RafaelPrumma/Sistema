@using System.Globalization
@using Sistema.APP.DTOs
@model ProventosPaginaDto
@{
    ViewData["Title"] = "Proventos";
    var br = CultureInfo.GetCultureInfo("pt-BR");
    var r = Model.Resumo;
    var totalPaginas = (int)Math.Ceiling(Model.TotalCount / (double)Math.Max(1, Model.PageSize));
}

@await Html.PartialAsync("_PageHeader", new PageHeaderViewModel
{
    Title = "Proventos",
    Description = "Renda da carteira: dividendos, JCP e rendimentos de FII (Brapi, cruzados com a posição na data-com) e rendimentos de earn/staking da Binance (valorados em BRL na data)."
})

<div class="row g-3 mb-3">
    <div class="col-6 col-lg-3">
        <div class="card h-100"><div class="card-body">
            <div class="small text-secondary">Recebido no mês</div>
            <div class="fs-4 fw-semibold">@r.RecebidoMes.ToString("C2", br)</div>
        </div></div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100"><div class="card-body">
            <div class="small text-secondary">Recebido no ano</div>
            <div class="fs-4 fw-semibold">@r.RecebidoAno.ToString("C2", br)</div>
        </div></div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100"><div class="card-body">
            <div class="small text-secondary">Total recebido</div>
            <div class="fs-4 fw-semibold">@r.RecebidoTotal.ToString("C2", br)</div>
        </div></div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100"><div class="card-body">
            <div class="small text-secondary">A receber (anunciado)</div>
            <div class="fs-4 fw-semibold">@r.AReceber.ToString("C2", br)</div>
        </div></div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <h5 class="mb-0">Baldes do ano</h5>
            <span class="small text-secondary">Resultado realizado e renda recebida</span>
        </div>
        <div class="row g-3">
            @foreach (var balde in Model.Baldes)
            {
                var cls = balde.Codigo == "TRADE"
                    ? (balde.Valor >= 0 ? "bg-primary" : "bg-danger")
                    : "bg-success";
                <div class="col-12 col-lg-6">
                    <div class="border rounded-2 p-3 h-100">
                        <div class="d-flex justify-content-between gap-3 mb-2">
                            <div>
                                <div class="fw-semibold">@balde.Rotulo</div>
                                <div class="small text-secondary">@balde.Status · @balde.Quantidade.ToString("N0", br) eventos</div>
                            </div>
                            <div class="text-end">
                                <div class="fs-5 fw-semibold">@balde.Valor.ToString("C2", br)</div>
                                <div class="small text-secondary">@balde.Percentual.ToString("N1", br)% do fluxo</div>
                            </div>
                        </div>
                        <div class="progress" style="height: 10px;">
                            <div class="progress-bar @cls" role="progressbar" style="width: @balde.Percentual.ToString("N0", CultureInfo.InvariantCulture)%"></div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
            <h5 class="mb-0">Proventos por mês</h5>
            <div class="d-flex flex-wrap gap-2 align-items-center">
                @foreach (var periodo in Model.Periodos)
                {
                    <span class="badge text-bg-light border fw-normal">@periodo.Rotulo: <strong>@((periodo.Recebido + periodo.AReceber).ToString("C2", br))</strong></span>
                }
            </div>
        </div>
        <div id="chartProventosMensais" style="min-height:300px;"></div>
    </div>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <form method="get" class="flex-grow-1">
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input class="form-control" name="termo" value="@ViewBag.Termo" placeholder="Buscar por ticker, ativo ou tipo (Dividendo, JCP, Rendimento)" />
            <button class="btn btn-primary" type="submit">Buscar</button>
        </div>
    </form>
    <form method="post" asp-action="AtualizarProventos">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-primary"><i class="bi bi-arrow-repeat me-1"></i>Atualizar proventos</button>
    </form>
</div>

<div class="card">
    <div class="card-body table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Pagamento</th>
                    <th>Data-com</th>
                    <th>Ativo</th>
                    <th>Tipo</th>
                    <th class="text-end">Qtd</th>
                    <th class="text-end">R$/cota</th>
                    <th class="text-end">Bruto</th>
                    <th class="text-end">IRRF</th>
                    <th class="text-end">Líquido</th>
                    <th>Tributação</th>
                    <th>Fonte</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Itens.Count == 0)
                {
                    <tr><td colspan="11" class="text-center text-secondary py-4">
                        Nenhum provento ainda. Clique em <strong>Atualizar proventos</strong> — B3 precisa do token Brapi (sem ele, só alguns tickers); earn da Binance vem da importação.
                    </td></tr>
                }
                @foreach (var item in Model.Itens)
                {
                    <tr>
                        <td>@(item.DataPagamento?.ToString("dd/MM/yyyy", br))</td>
                        <td class="text-secondary">@(item.DataCom?.ToString("dd/MM/yyyy", br))</td>
                        <td>
                            <div class="fw-semibold">@item.Ticker</div>
                            <div class="small text-secondary">@item.Nome</div>
                        </td>
                        <td><span class="badge text-bg-secondary">@item.Tipo</span></td>
                        <td class="text-end">@(item.Quantidade?.ToString("N0", br))</td>
                        <td class="text-end">@(item.ValorPorAcao?.ToString("N6", br))</td>
                        <td class="text-end">@item.Valor.ToString("C2", br)</td>
                        <td class="text-end text-secondary">@(item.ImpostoRetido > 0 ? item.ImpostoRetido.ToString("C2", br) : "—")</td>
                        <td class="text-end fw-semibold">@item.ValorLiquido.ToString("C2", br)</td>
                        <td class="small">@item.Tributacao</td>
                        <td><span class="badge text-bg-light border">@item.Fonte</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center">
        <span>@Model.TotalCount proventos</span>
        <div class="btn-group">
            <a class="btn btn-sm btn-outline-secondary @(Model.Page <= 1 ? "disabled" : "")" asp-route-page="@(Model.Page - 1)" asp-route-termo="@ViewBag.Termo">Anterior</a>
            <span class="btn btn-sm btn-outline-secondary disabled">@Model.Page / @Math.Max(1, totalPaginas)</span>
            <a class="btn btn-sm btn-outline-secondary @(Model.Page >= totalPaginas ? "disabled" : "")" asp-route-page="@(Model.Page + 1)" asp-route-termo="@ViewBag.Termo">Próxima</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/apexcharts/apexcharts.min.js" asp-append-version="true"></script>
    <script>
        (function () {
            var labels = @Html.Raw(Json.Serialize(Model.Mensais.Select(m => m.Rotulo)));
            var recebido = @Html.Raw(Json.Serialize(Model.Mensais.Select(m => m.Recebido)));
            var aReceber = @Html.Raw(Json.Serialize(Model.Mensais.Select(m => m.AReceber)));
            var el = document.querySelector('#chartProventosMensais');
            if (!el || typeof ApexCharts === 'undefined') return;

            var brl = function (v) { return (v || 0).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }); };
            var options = {
                chart: { type: 'bar', height: 300, stacked: true, fontFamily: 'inherit', toolbar: { show: false } },
                series: [
                    { name: 'Recebido', data: recebido },
                    { name: 'A receber', data: aReceber }
                ],
                colors: ['#198754', '#0dcaf0'],
                plotOptions: { bar: { columnWidth: '55%', borderRadius: 4 } },
                dataLabels: { enabled: false },
                grid: { borderColor: 'rgba(128,128,128,.15)' },
                xaxis: { categories: labels, axisBorder: { show: false }, axisTicks: { show: false } },
                yaxis: { labels: { formatter: function (v) { return 'R$ ' + (v || 0).toLocaleString('pt-BR', { maximumFractionDigits: 0 }); } } },
                legend: { position: 'top', horizontalAlign: 'left' },
                tooltip: { y: { formatter: brl } }
            };
            new ApexCharts(el, options).render();
        })();
    </script>
}
