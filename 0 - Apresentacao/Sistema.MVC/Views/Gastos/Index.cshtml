@using System.Globalization
@using Sistema.APP.DTOs
@model GastosVisaoGeralDto
@{
    ViewData["Title"] = "Gastos — Visão geral";
    var br = CultureInfo.GetCultureInfo("pt-BR");
    string Moeda(decimal v) => v.ToString("C2", br);
    var nomesMes = new[] { "", "janeiro", "fevereiro", "março", "abril", "maio", "junho", "julho", "agosto", "setembro", "outubro", "novembro", "dezembro" };
    var mesNome = Model.Mes >= 1 && Model.Mes <= 12 ? nomesMes[Model.Mes] : Model.Mes.ToString(br);
    var saldoPositivo = Model.SaldoDoMes >= 0m;
}

@await Html.PartialAsync("_PageHeader", new PageHeaderViewModel
{
    Title = "Gastos",
    Description = "Controle de gastos e receitas a partir das faturas do cartão e dos extratos da conta."
})

@await Html.PartialAsync("_FlashMessages")

@if (!Model.Disponivel)
{
    <div class="alert alert-warning d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <div>
            Não foi possível carregar os lançamentos de gastos agora. A tela continua disponível e os
            números aparecem assim que a importação for concluída.
        </div>
    </div>
}

<div class="row g-3 mb-3">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-secondary small text-uppercase">Lançamentos (total)</div>
                <div class="fs-3 fw-semibold">@Model.TotalLancamentos.ToString("N0", br)</div>
                <div class="text-secondary small">@Model.LancamentosNoMes.ToString("N0", br) em @mesNome/@Model.Ano</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-secondary small text-uppercase">Receitas do mês</div>
                <div class="fs-3 fw-semibold text-success">@Moeda(Model.ReceitaDoMes)</div>
                <div class="text-secondary small">Entradas de @mesNome</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-secondary small text-uppercase">Despesas do mês</div>
                <div class="fs-3 fw-semibold text-danger">@Moeda(Model.DespesaDoMes)</div>
                <div class="text-secondary small">Saídas de @mesNome</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-secondary small text-uppercase">Saldo do mês</div>
                <div class="fs-3 fw-semibold @(saldoPositivo ? "text-success" : "text-danger")">@Moeda(Model.SaldoDoMes)</div>
                <div class="text-secondary small">Receitas − Despesas</div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-2">
        <div>
            <div class="text-secondary small text-uppercase">Aportes e transferências do mês</div>
            <div class="fs-5 fw-semibold">@Moeda(Model.AporteDoMes)</div>
        </div>
        <div class="text-secondary small" style="max-width: 34rem;">
            Compra de ações/FII, aplicações e transferências para a corretora são tratadas como
            <strong>aporte</strong> (investimento), não como despesa — por isso não entram no cálculo de
            receitas × despesas acima.
        </div>
    </div>
</div>

<div class="alert alert-info d-flex align-items-start" role="alert">
    <i class="bi bi-tools me-2 mt-1"></i>
    <div>
        <strong>Em construção.</strong> Esta é a visão geral inicial do módulo de Gastos. As próximas
        etapas trazem a categorização com ajuste manual, os gráficos por categoria e evolução, o
        orçamento (planejado × realizado) e o fluxo de caixa. Por enquanto, os lançamentos são
        materializados automaticamente a partir das faturas e extratos já importados.
    </div>
</div>
