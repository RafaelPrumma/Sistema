@model Sistema.MVC.Models.PageHeaderViewModel
<div class="page-heading">
    <div>
        <span class="page-heading-eyebrow">Sistema</span>
        <h1>@Model.Title</h1>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p>@Model.Description</p>
        }
    </div>
</div>
