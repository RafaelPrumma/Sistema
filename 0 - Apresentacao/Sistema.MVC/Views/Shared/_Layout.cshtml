@using Microsoft.AspNetCore.Http
@using System.Globalization
@inject Sistema.APP.Services.Interfaces.ITemaAppService TemaService
@inject Sistema.APP.Services.Interfaces.IMensagemAppService MensagemService
@{ 
    var sessionUserId = Context.Session.GetInt32("UserId");
    var claimUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var userId = sessionUserId ?? (int.TryParse(claimUserId, out var parsedId) ? parsedId : 0);
    if (sessionUserId is null && userId > 0)
    {
        Context.Session.SetInt32("UserId", userId);
    }

    var sessionUserName = Context.Session.GetString("UserName");
    var claimUserName = User.Identity?.Name;
    var userName = !string.IsNullOrWhiteSpace(sessionUserName) ? sessionUserName : (claimUserName ?? "Usuário");
    if (sessionUserName is null && !string.IsNullOrWhiteSpace(claimUserName))
    {
        Context.Session.SetString("UserName", claimUserName);
    }
    var tema = userId > 0 ? await TemaService.BuscarPorUsuarioIdAsync(userId) : null;
    string headerColor = tema?.CorHeader ?? "#0d6efd";
    string leftColor = tema?.CorBarraEsquerda ?? "#0d6efd";
    string rightColor = tema?.CorBarraDireita ?? "#f8f9fa";
    string footerColor = tema?.CorFooter ?? "#0d6efd";
    bool modoEscuro = tema?.ModoEscuro ?? false;
    bool headerFixo = tema?.HeaderFixo ?? false;
    bool footerFixo = tema?.FooterFixo ?? false;
    bool menuExpandido = tema?.MenuLateralExpandido ?? true;
    var unreadMessages = userId > 0 ? await MensagemService.ContarNaoLidasAsync(userId) : 0;
    string EstaAtivo(string controller, string? action = null)
    {
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        var controllerMatch = string.Equals(controller, currentController, StringComparison.OrdinalIgnoreCase);
        var actionMatch = action is null || string.Equals(action, currentAction, StringComparison.OrdinalIgnoreCase);
        return controllerMatch && actionMatch ? "active" : string.Empty;
    }
    string ObterClasseTexto(string hex)
    {
        if (string.IsNullOrWhiteSpace(hex)) return "text-dark";
        hex = hex.TrimStart('#');
        if (hex.Length == 6)
        {
            var r = int.Parse(hex[..2], NumberStyles.HexNumber);
            var g = int.Parse(hex[2..4], NumberStyles.HexNumber);
            var b = int.Parse(hex[4..6], NumberStyles.HexNumber);
            var lum = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
            return lum > 0.5 ? "text-dark" : "text-white";
        }
        return "text-dark";
    }

    string headerText = ObterClasseTexto(headerColor);
    string leftText = ObterClasseTexto(leftColor);
    string rightText = ObterClasseTexto(rightColor);
    string footerText = ObterClasseTexto(footerColor);
    string headerNavbarClass = headerText == "text-white" ? "navbar-dark" : "navbar-light";
    string headerFixedClass = headerFixo ? "fixed-top" : string.Empty;
    string footerFixedClass = footerFixo ? "fixed-bottom" : string.Empty;
}
<!DOCTYPE html>
<html lang="pt-BR" style="color-scheme: light dark; --header-bg:@headerColor; --sidebar-bg:@leftColor; --rightbar-bg:@rightColor; --footer-bg:@footerColor;">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema.MVC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/lib/izitoast/css/iziToast.min.css" />
    <link rel="stylesheet" href="~/lib/izimodal/css/iziModal.min.css" />
    <link rel="stylesheet" href="~/lib/aos/aos.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body data-bs-theme="@(modoEscuro ? "dark" : "light")">
    <div class="layout-root">
        <nav id="sidebarMenu" class="app-menu sidebar-bg @leftText" data-menu-expanded="@menuExpandido.ToString().ToLowerInvariant()" aria-label="Menu principal">
            <div class="menu-panels-track">
                <div class="menu-panel menu-panel--root" id="menuPanelRoot">
                    <ul class="menu-list">
                        <li class="menu-section-label text-uppercase small">Módulos</li>
                        <li class="menu-item" data-panel="menuPanelHome">
                            <a href="#" class="menu-link @leftText @EstaAtivo("Home")">
                                <i class="bi bi-house"></i>
                                <span>Home</span>
                            </a>
                            <button class="menu-arrow" aria-label="Abrir submenu Home"><i class="bi bi-chevron-right"></i></button>
                        </li>
                        <li class="menu-item" data-panel="menuPanelFinancas">
                            <a href="#" class="menu-link @leftText @EstaAtivo("MinhasFinancas")">
                                <i class="bi bi-graph-up-arrow"></i>
                                <span>Minhas Finanças</span>
                            </a>
                            <button class="menu-arrow" aria-label="Abrir submenu Minhas Finanças"><i class="bi bi-chevron-right"></i></button>
                        </li>
                        <li class="menu-item" data-panel="menuPanelAcesso">
                            <a href="#" class="menu-link @leftText @EstaAtivo("Account")">
                                <i class="bi bi-shield-lock"></i>
                                <span>Acesso</span>
                            </a>
                            <button class="menu-arrow" aria-label="Abrir submenu Acesso"><i class="bi bi-chevron-right"></i></button>
                        </li>
                        <li class="menu-item" data-panel="menuPanelMensagens">
                            <a href="#" class="menu-link @leftText @EstaAtivo("Mensagem")">
                                <i class="bi bi-envelope"></i>
                                <span>Comunicação</span>
                                @if (unreadMessages > 0)
                                {
                                    <span class="badge bg-primary ms-auto">@unreadMessages</span>
                                }
                            </a>
                            <button class="menu-arrow" aria-label="Abrir submenu Comunicação"><i class="bi bi-chevron-right"></i></button>
                        </li>
                        <li class="menu-item" data-panel="menuPanelAdmin">
                            <a href="#" class="menu-link @leftText @EstaAtivo("Configuracao")">
                                <i class="bi bi-gear"></i>
                                <span>Administração</span>
                            </a>
                            <button class="menu-arrow" aria-label="Abrir submenu Administração"><i class="bi bi-chevron-right"></i></button>
                        </li>
                        <li class="menu-item" data-panel="menuPanelDocs">
                            <a href="#" class="menu-link @leftText @EstaAtivo("Documentacao")">
                                <i class="bi bi-book"></i>
                                <span>Documentação</span>
                            </a>
                            <button class="menu-arrow" aria-label="Abrir submenu Documentação"><i class="bi bi-chevron-right"></i></button>
                        </li>
                    </ul>
                </div>
                <div class="menu-panel menu-panel--sub" id="menuPanelHome"><div class="menu-panel-header"><button class="menu-back" aria-label="Voltar"><i class="bi bi-chevron-left"></i><span>Voltar</span></button><span class="menu-panel-title">Home</span></div><ul class="menu-list"><li><a asp-controller="Home" asp-action="Index" class="menu-sublink @leftText">Dashboard</a></li><li><a asp-controller="Home" asp-action="Privacy" class="menu-sublink @leftText">Privacidade</a></li></ul></div>
                <div class="menu-panel menu-panel--sub" id="menuPanelFinancas"><div class="menu-panel-header"><button class="menu-back" aria-label="Voltar"><i class="bi bi-chevron-left"></i><span>Voltar</span></button><span class="menu-panel-title">Minhas Finanças</span></div><ul class="menu-list"><li><a asp-controller="MinhasFinancas" asp-action="Index" class="menu-sublink @leftText">Dashboard</a></li><li><a asp-controller="MinhasFinancas" asp-action="Documentos" class="menu-sublink @leftText">Documentos</a></li><li><a asp-controller="MinhasFinancas" asp-action="OperacoesB3" class="menu-sublink @leftText">Operações B3</a></li><li><a asp-controller="MinhasFinancas" asp-action="OperacoesCripto" class="menu-sublink @leftText">Cripto</a></li><li><a asp-controller="MinhasFinancas" asp-action="Posicoes" class="menu-sublink @leftText">Posições estimadas</a></li><li><a asp-controller="MinhasFinancas" asp-action="Alertas" class="menu-sublink @leftText">Alertas</a></li></ul></div>
                <div class="menu-panel menu-panel--sub" id="menuPanelAcesso"><div class="menu-panel-header"><button class="menu-back" aria-label="Voltar"><i class="bi bi-chevron-left"></i><span>Voltar</span></button><span class="menu-panel-title">Acesso</span></div><ul class="menu-list"><li><a asp-controller="Account" asp-action="ChangePassword" class="menu-sublink @leftText">Segurança</a></li><li><a href="/api/log/acesso" class="menu-sublink @leftText">AcessoLog (API)</a></li></ul></div>
                <div class="menu-panel menu-panel--sub" id="menuPanelMensagens"><div class="menu-panel-header"><button class="menu-back" aria-label="Voltar"><i class="bi bi-chevron-left"></i><span>Voltar</span></button><span class="menu-panel-title">Comunicação</span></div><ul class="menu-list"><li><a asp-controller="Mensagem" asp-action="Index" class="menu-sublink @leftText">Feed</a></li><li><a asp-controller="Mensagem" asp-action="CaixaSaida" class="menu-sublink @leftText">Caixa de saída</a></li><li><a asp-controller="Mensagem" asp-action="Nova" class="menu-sublink @leftText">Nova publicação</a></li><li><a href="/api/log/comunicacao" class="menu-sublink @leftText">ComunicacaoLog (API)</a></li></ul></div>
                <div class="menu-panel menu-panel--sub" id="menuPanelAdmin"><div class="menu-panel-header"><button class="menu-back" aria-label="Voltar"><i class="bi bi-chevron-left"></i><span>Voltar</span></button><span class="menu-panel-title">Administração</span></div><ul class="menu-list"><li><a asp-controller="Configuracao" asp-action="Index" class="menu-sublink @leftText">Configurações</a></li><li><a asp-controller="Tema" asp-action="Edit" class="menu-sublink @leftText">Tema</a></li><li><a href="/api/log/administracao" class="menu-sublink @leftText">AdministracaoLog (API)</a></li></ul></div>
                <div class="menu-panel menu-panel--sub" id="menuPanelDocs"><div class="menu-panel-header"><button class="menu-back" aria-label="Voltar"><i class="bi bi-chevron-left"></i><span>Voltar</span></button><span class="menu-panel-title">Documentação</span></div><ul class="menu-list"><li><a asp-controller="Documentacao" asp-action="Index" asp-fragment="mensagens" class="menu-sublink @leftText">Mensagens</a></li><li><a asp-controller="Documentacao" asp-action="Index" asp-fragment="logs" class="menu-sublink @leftText">Logs e auditoria</a></li><li><a asp-controller="Documentacao" asp-action="Index" asp-fragment="scripts" class="menu-sublink @leftText">Scripts</a></li></ul></div>
            </div>
        </nav>
        <div class="layout-main">
            <header class="navbar @headerNavbarClass @headerFixedClass header-bg">
                <div class="container-fluid"><div class="d-flex align-items-center gap-2"><button class="btn btn-link @headerText menu-hamburger" aria-label="Abrir/fechar menu" aria-expanded="true" aria-controls="sidebarMenu"><i class="bi bi-list fs-4"></i></button><a class="navbar-brand @headerText" asp-controller="Home" asp-action="Index">Sistema.MVC</a></div><div class="ms-auto d-flex align-items-center"><button class="btn btn-link @headerText" type="button" id="temaToggle"><i class="bi bi-palette"></i></button><div class="dropdown"><a class="nav-link dropdown-toggle @headerText" href="#" id="userMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">@userName</a><ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu"><li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">Alterar Senha</a></li><li><hr class="dropdown-divider" /></li><li><a class="dropdown-item" asp-controller="Account" asp-action="Logout">Sair</a></li></ul></div></div></div>
            </header>
            <main id="main" role="main" class="layout-content p-3" data-aos="fade-up" data-aos-delay="50" data-aos-duration="750" data-aos-easing="ease-out-quart"><a class="visually-hidden-focusable" href="#main">Pular para conteúdo</a>@RenderBody()</main>
            <footer class="footer @footerText @footerFixedClass footer-bg"><div class="container">&copy; 2025 - Sistema.MVC - <a class="@footerText" asp-controller="Home" asp-action="Privacy">Privacy</a></div></footer>
        </div>
    </div>
    <div id="menuBackdrop" class="menu-backdrop" aria-hidden="true"></div>
    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.js"></script>
    <script src="~/lib/izitoast/js/iziToast.min.js"></script>
    <script src="~/lib/izimodal/js/iziModal.min.js"></script>
    <script src="~/lib/aos/aos.js"></script>
    <script src="~/js/menu.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <div id="temaSidebarBackdrop" class="tema-sidebar-backdrop" aria-hidden="true"></div>
    <aside id="temaSidebar" class="tema-sidebar @rightText rightbar-bg" aria-hidden="true">
        <form asp-controller="Tema" asp-action="Edit" method="post" class="p-3">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h5 class="mb-0">Preferências de Tema</h5>
                <button type="button" class="btn btn-sm btn-outline-secondary" id="temaSidebarClose" aria-label="Fechar painel de tema">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="mb-3">
                <label class="form-label">Modo</label>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="ModoEscuro" value="false" @(modoEscuro ? "" : "checked") />
                    <label class="form-check-label">Claro</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="ModoEscuro" value="true" @(modoEscuro ? "checked" : "") />
                    <label class="form-check-label">Escuro</label>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Presets</label>
                <div class="theme-preset-grid">
                    <button type="button" class="theme-preset" data-theme-preset="executivo">
                        <span class="theme-preset-swatches"><i style="background:#0f172a"></i><i style="background:#2563eb"></i><i style="background:#f8fafc"></i></span>
                        Executivo
                    </button>
                    <button type="button" class="theme-preset" data-theme-preset="financeiro">
                        <span class="theme-preset-swatches"><i style="background:#064e3b"></i><i style="background:#0f766e"></i><i style="background:#ecfdf5"></i></span>
                        Financeiro
                    </button>
                    <button type="button" class="theme-preset" data-theme-preset="grafite">
                        <span class="theme-preset-swatches"><i style="background:#111827"></i><i style="background:#374151"></i><i style="background:#1f2937"></i></span>
                        Grafite
                    </button>
                </div>
            </div>
            <div class="theme-mini-preview mb-3" aria-hidden="true">
                <span></span>
                <strong></strong>
                <em></em>
            </div>
            <div class="mb-3">
                <label class="form-label" for="CorHeader">Cor do Header</label>
                <input type="color" class="form-control form-control-color" name="CorHeader" id="CorHeader" value="@headerColor" />
            </div>
            <div class="mb-3">
                <label class="form-label" for="CorBarraEsquerda">Barra Lateral Esquerda</label>
                <input type="color" class="form-control form-control-color" name="CorBarraEsquerda" id="CorBarraEsquerda" value="@leftColor" />
            </div>
            <div class="mb-3">
                <label class="form-label" for="CorBarraDireita">Barra Lateral Direita</label>
                <input type="color" class="form-control form-control-color" name="CorBarraDireita" id="CorBarraDireita" value="@rightColor" />
            </div>
            <div class="mb-3">
                <label class="form-label" for="CorFooter">Rodapé</label>
                <input type="color" class="form-control form-control-color" name="CorFooter" id="CorFooter" value="@footerColor" />
            </div>
            <div class="form-check form-switch mb-2">
                <input class="form-check-input" type="checkbox" name="HeaderFixo" id="HeaderFixo" value="true" @(headerFixo ? "checked" : string.Empty) />
                <input type="hidden" name="HeaderFixo" value="false" />
                <label class="form-check-label" for="HeaderFixo">Header fixo</label>
            </div>
            <div class="form-check form-switch mb-2">
                <input class="form-check-input" type="checkbox" name="FooterFixo" id="FooterFixo" value="true" @(footerFixo ? "checked" : string.Empty) />
                <input type="hidden" name="FooterFixo" value="false" />
                <label class="form-check-label" for="FooterFixo">Footer fixo</label>
            </div>
            <div class="form-check form-switch mb-2">
                <input class="form-check-input" type="checkbox" name="MenuLateralExpandido" id="MenuLateralExpandido" value="true" @(menuExpandido ? "checked" : string.Empty) />
                <input type="hidden" name="MenuLateralExpandido" value="false" />
                <label class="form-check-label" for="MenuLateralExpandido">Menu lateral expandido</label>
            </div>
            <button type="submit" class="btn btn-primary">Salvar</button>
        </form>
    </aside>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
