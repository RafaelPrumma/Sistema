@model Sistema.MVC.Models.MensagemViewModel
@{
    ViewData["Title"] = "Caixa de saida";
}

<div class="admin-dashboard">
    @await Html.PartialAsync("_PageHeader", new PageHeaderViewModel
    {
        Title = "Caixa de saida",
        Description = "Acompanhe mensagens e publicacoes enviadas por voce."
    })

    <div class="surface-card">
        <div class="surface-card-header">
            <div>
                <h3>Enviadas</h3>
                <p>@Model.TotalItems item(ns) encontrados.</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-inbox"></i>
                    Feed
                </a>
                <a asp-action="Nova" class="btn btn-primary">
                    <i class="bi bi-pencil-square"></i>
                    Nova
                </a>
            </div>
        </div>

        @if (Model.Mensagens.Count == 0)
        {
            <div class="empty-state">
                <i class="bi bi-send"></i>
                <strong>Nenhuma mensagem enviada</strong>
                <span>As mensagens enviadas aparecem aqui.</span>
            </div>
        }
        else
        {
            <div class="message-feed">
                @foreach (var m in Model.Mensagens)
                {
                    <article class="message-card">
                        <div class="message-avatar"><i class="bi bi-send"></i></div>
                        <div>
                            <div class="message-card-title">
                                <strong>@m.Assunto</strong>
                                <span class="badge text-bg-light">@m.Tipo</span>
                            </div>
                            <p class="message-card-body">
                                Destino: @(string.IsNullOrWhiteSpace(m.DestinatarioNome) ? (string.IsNullOrWhiteSpace(m.PerfilNome) ? "Publicacao" : m.PerfilNome) : m.DestinatarioNome)
                            </p>
                            <div class="message-card-meta">
                                <span class="badge text-bg-light">@m.DataInclusao.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                <span class="badge @(m.Status.ToString() == "Ativa" ? "text-bg-success" : "text-bg-secondary")">@m.Status</span>
                            </div>
                        </div>
                        <div class="message-card-actions">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Detalhe" asp-route-id="@m.Id">Abrir</a>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</div>
