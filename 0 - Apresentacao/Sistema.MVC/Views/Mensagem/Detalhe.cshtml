@model Sistema.APP.DTOs.MensagemThreadDto
@{
    ViewData["Title"] = Model.Assunto;
}

<div class="admin-dashboard">
    @await Html.PartialAsync("_PageHeader", new PageHeaderViewModel
    {
        Title = Model.Assunto,
        Description = "Thread de comunicacao interna com respostas e reacoes."
    })

    <div class="surface-card">
        <div class="surface-card-header">
            <div class="d-flex gap-2 flex-wrap">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i>
                    Feed
                </a>
                <a asp-action="CaixaSaida" class="btn btn-outline-secondary">
                    <i class="bi bi-send"></i>
                    Enviadas
                </a>
            </div>
            <a asp-action="Nova" asp-route-mensagemPaiId="@Model.Id" asp-route-destinatarioId="@Model.RemetenteId" class="btn btn-primary">
                <i class="bi bi-reply"></i>
                Responder
            </a>
        </div>

        @await Html.PartialAsync("_MensagemThread", Model)
    </div>
</div>
