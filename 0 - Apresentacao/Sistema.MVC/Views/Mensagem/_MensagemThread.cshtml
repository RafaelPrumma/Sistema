@model Sistema.APP.DTOs.MensagemThreadDto
@using Sistema.CORE.Entities

<div class="message-thread-node mb-3">
    <div class="d-flex justify-content-between gap-3 flex-wrap">
        <div class="d-flex gap-3">
            <span class="message-avatar">
                <i class="bi @(Model.Tipo == PublicacaoTipo.Aviso ? "bi-megaphone" : Model.Tipo == PublicacaoTipo.PostSetor ? "bi-building" : "bi-person")"></i>
            </span>
            <div>
                <div class="message-card-title">
                    <strong>@(string.IsNullOrWhiteSpace(Model.RemetenteNome) ? "Sistema" : Model.RemetenteNome)</strong>
                    <span class="badge text-bg-light">@Model.Tipo</span>
                    @if (!string.IsNullOrWhiteSpace(Model.PerfilNome))
                    {
                        <span class="badge text-bg-secondary">@Model.PerfilNome</span>
                    }
                </div>
                <small class="text-muted">@Model.DataInclusao.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
            </div>
        </div>
        <a class="btn btn-sm btn-outline-primary" asp-action="Nova" asp-controller="Mensagem" asp-route-mensagemPaiId="@Model.Id" asp-route-destinatarioId="@Model.RemetenteId">
            <i class="bi bi-reply"></i>
            Responder
        </a>
    </div>

    <p class="message-card-body mt-3">@Model.Corpo</p>

    <div class="message-card-meta">
        <form method="post" asp-action="Reagir" asp-controller="Mensagem" class="d-inline-flex gap-1 flex-wrap">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button class="btn btn-sm btn-outline-secondary" name="tipoReacao" value="@TipoReacao.Curtir" title="Curtir">
                <i class="bi bi-hand-thumbs-up"></i>
            </button>
            <button class="btn btn-sm btn-outline-secondary" name="tipoReacao" value="@TipoReacao.Aplaudir" title="Aplaudir">
                <i class="bi bi-stars"></i>
            </button>
            <button class="btn btn-sm btn-outline-secondary" name="tipoReacao" value="@TipoReacao.Apoiar" title="Apoiar">
                <i class="bi bi-heart"></i>
            </button>
        </form>

        @if (Model.Reacoes?.Count > 0)
        {
            foreach (var reacao in Model.Reacoes)
            {
                <span class="badge text-bg-light">@reacao.Key: @reacao.Value</span>
            }
        }
    </div>
</div>

@if (Model.Respostas?.Any() == true)
{
    <div class="ms-3 ms-md-4 ps-3 border-start">
        @foreach (var resposta in Model.Respostas.OrderBy(r => r.DataInclusao))
        {
            @await Html.PartialAsync("_MensagemThread", resposta)
        }
    </div>
}
