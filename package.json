{
  "name": "sistema",
  "version": "1.0.0",
  "description": "Projeto de exemplo em .NET 8 utilizando arquitetura em camadas.",
  "main": "index.js",
  "scripts": {
    "css:build": "node \"node_modules/sass/sass.js\" \"0 - Apresentacao/Sistema.MVC/wwwroot/css/site.scss\" \"0 - Apresentacao/Sistema.MVC/wwwroot/css/site.css\" --style=expanded --no-source-map",
    "css:min": "node \"node_modules/sass/sass.js\" \"0 - Apresentacao/Sistema.MVC/wwwroot/css/site.scss\" \"0 - Apresentacao/Sistema.MVC/wwwroot/css/site.min.css\" --style=compressed --no-source-map",
    "css:watch": "node \"node_modules/sass/sass.js\" --watch \"0 - Apresentacao/Sistema.MVC/wwwroot/css/site.scss\":\"0 - Apresentacao/Sistema.MVC/wwwroot/css/site.css\" --style=expanded --no-source-map",
    "build": "npm run css:build && npm run css:min && node \"node_modules/vite/bin/vite.js\" build",
    "watch": "node \"node_modules/vite/bin/vite.js\" build --watch --mode development",
    "dev": "node \"node_modules/vite/bin/vite.js\"",
    "test": "echo \"No tests\"",
    "test:layout": "node artifacts/screenshots/capture-layout.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "aos": "^2.3.4",
    "bootstrap-icons": "^1.10.5",
    "izimodal": "^1.6.0",
    "izitoast": "^1.4.0",
    "jquery": "^3.7.1",
    "playwright": "^1.59.1",
    "sass": "^1.91.0",
    "vite": "^5.0.0"
  }
}
